# ============================================================
# Variables de entorno - Mentoría León dLocal API (PRODUCCIÓN)
# ============================================================
# Uso:
#   - Local: copiar este archivo a `.env` y reemplazar los <<< ... >>>
#   - Render: cargar cada variable en Dashboard → Environment
#
# IMPORTANTE: NO commitear el `.env` con secrets (ya está gitignoreado).
# ============================================================


# ============================================================
# 1. DLOCAL GO — Credenciales de API
# ============================================================
# Sacalas del panel de dLocal Go: https://dlocalgo.com → Integración → API Keys
# Tené ambos sets (sandbox y producción) a mano.
DLOCAL_API_KEY=<<< API_KEY_DE_PRODUCCION >>>
DLOCAL_SECRET_KEY=<<< SECRET_KEY_DE_PRODUCCION >>>

# Endpoint de dLocal Go.
# Producción:
DLOCAL_API_URL=https://api.dlocalgo.com
# Sandbox (descomentar y comentar la línea de arriba para testear):
# DLOCAL_API_URL=https://api-sbx.dlocalgo.com


# ============================================================
# 2. URL PÚBLICA DE ESTA API
# ============================================================
# Es donde corre este backend; dLocal usa esta URL para mandar webhooks.
# DEBE incluir https:// y NO debe terminar con slash.
#
# - En Render (subdominio default):
APP_BASE_URL=https://mentoria-leon-api.onrender.com
# - Si configurás dominio custom, reemplazá por: https://api.tu-dominio.com


# ============================================================
# 3. WEBHOOK A TERCEROS (AutomatiChat u otro)
# ============================================================
# Cada vez que llega un webhook de dLocal, esta API reenvía los datos del
# pago a la URL de abajo. Si no tenés un webhook 3rd party, podés poner
# un endpoint dummy tipo https://webhook.site/... mientras testeás.
THIRD_PARTY_WEBHOOK_URL=<<< URL_DEL_ESCENARIO_DE_AUTOMATICHAT >>>


# ============================================================
# 4. URLs DE RETORNO POST-CHECKOUT (todas opcionales)
# ============================================================
# Si están vacías, dLocal muestra su propia pantalla de estado y NO redirige
# al cliente a tu sitio. Setealas si querés llevarte al cliente de vuelta.
#
# dLocal agrega query string con el resultado del pago, por ejemplo:
#   ?payment_id=D-4-abc123&status=PAID&order_id=order_xyz

# Botón "Volver/Cancelar" del checkout → tu landing de venta:
DLOCAL_CANCEL_URL=<<< URL_DE_TU_LANDING_DE_VENTA >>>

# (Opcionales) Páginas dedicadas a cada estado del pago:
# DLOCAL_SUCCESS_URL=https://tu-dominio.com/pago-exitoso
# DLOCAL_ERROR_URL=https://tu-dominio.com/pago-rechazado
# DLOCAL_PENDING_URL=https://tu-dominio.com/pago-pendiente


# ============================================================
# 5. BRANDING DEL CHECKOUT
# ============================================================
# Lo que ve el cliente en la pantalla de pago de dLocal.
MERCHANT_NAME=Mentoría León
PAYMENT_DESCRIPTION=Mentoría León


# ============================================================
# 6. CONFIGURACIÓN GENERAL
# ============================================================
# production / development → afecta logs, reload, manejo de errores.
ENVIRONMENT=production

# Nivel de logs: DEBUG / INFO / WARNING / ERROR
# - INFO: recomendado en producción
# - DEBUG: solo si estás debuggeando un problema
LOG_LEVEL=INFO
