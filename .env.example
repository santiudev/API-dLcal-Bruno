# ============================================================
# Variables de entorno - Mentoría León dLocal API (PRODUCCIÓN)
# ============================================================
# Uso:
#   - Local: copiar este archivo a `.env` y reemplazar los <<< ... >>>
#   - Render: cargar cada variable en Dashboard → Environment
#
# IMPORTANTE: NO commitear el `.env` con secrets (ya está gitignoreado).
# ============================================================


# ============================================================
# 1. DLOCAL GO — Credenciales de API
# ============================================================
# Sacalas del panel de dLocal Go: https://dlocalgo.com → Integración → API Keys
# Tené ambos sets (sandbox y producción) a mano.
DLOCAL_API_KEY=<<< API_KEY_DE_PRODUCCION >>>
DLOCAL_SECRET_KEY=<<< SECRET_KEY_DE_PRODUCCION >>>

# Endpoint de dLocal Go.
# Producción:
DLOCAL_API_URL=https://api.dlocalgo.com
# Sandbox (descomentar y comentar la línea de arriba para testear):
# DLOCAL_API_URL=https://api-sbx.dlocalgo.com


# ============================================================
# 2. URL PÚBLICA DE ESTA API
# ============================================================
# Es donde corre este backend; dLocal usa esta URL para mandar webhooks.
# DEBE incluir https:// y NO debe terminar con slash.
#
# - En Render (subdominio default):
APP_BASE_URL=https://mentoria-leon-api.onrender.com
# - Si configurás dominio custom, reemplazá por: https://api.tu-dominio.com


# ============================================================
# 3. WEBHOOK A TERCEROS (AutomatiChat u otro)
# ============================================================
# Cada vez que llega un webhook de dLocal, esta API reenvía los datos del
# pago a la URL de abajo. Si no tenés un webhook 3rd party, podés poner
# un endpoint dummy tipo https://webhook.site/... mientras testeás.
THIRD_PARTY_WEBHOOK_URL=<<< URL_DEL_ESCENARIO_DE_AUTOMATICHAT >>>


# ============================================================
# 4. URLs DE RETORNO POST-CHECKOUT (todas opcionales)
# ============================================================
# Si están vacías, dLocal muestra su propia pantalla de estado y NO redirige
# al cliente a tu sitio. Setealas si querés llevarte al cliente de vuelta.
#
# dLocal agrega query string con el resultado del pago, por ejemplo:
#   ?payment_id=D-4-abc123&status=PAID&order_id=order_xyz

# Botón "Volver/Cancelar" del checkout → tu landing de venta:
DLOCAL_CANCEL_URL=<<< URL_DE_TU_LANDING_DE_VENTA >>>

# (Opcionales) Páginas dedicadas a cada estado del pago:
# DLOCAL_SUCCESS_URL=https://tu-dominio.com/pago-exitoso
# DLOCAL_ERROR_URL=https://tu-dominio.com/pago-rechazado
# DLOCAL_PENDING_URL=https://tu-dominio.com/pago-pendiente


# ============================================================
# 5. BRANDING DEL CHECKOUT
# ============================================================
# Lo que ve el cliente en la pantalla de pago de dLocal.
MERCHANT_NAME=Mentoría León
PAYMENT_DESCRIPTION=Mentoría León


# ============================================================
# 6. ONE-CLICK UPSELL (One Time Offer)
# ============================================================
# Requiere que dLocal Go habilite la feature en la cuenta del merchant
# (contactarlos por el chat del dashboard de dLocal Go).
#
# Cuando UPSELL_ENABLED=true, todos los checkouts se crean con allow_upsell=true,
# lo que limita los métodos de pago a SOLO tarjetas de crédito/débito.
# Después de un pago exitoso, hay una ventana de 15 minutos para confirmar el upsell
# (cobro extra one-click sin volver a pedir datos de tarjeta).
UPSELL_ENABLED=true

# Monto fijo del producto upsell (en USD)
UPSELL_AMOUNT=197

# Descripción que ve el cliente en el cargo del upsell
UPSELL_DESCRIPTION=Mentoría León - Extensión de 3 meses

# A/B test de precio (transparente al cliente, 50/50 sticky por order_id).
# Cuando UPSELL_AB_TEST_ENABLED=true, cada nuevo checkout se asigna al azar a:
#   - Variante A (control): UPSELL_AMOUNT (197)
#   - Variante B (prueba):  UPSELL_AMOUNT_VARIANT_B (147)
# La variante asignada queda guardada en cache y se respeta durante todo el
# flujo del cliente. Para ver los resultados, ir a:
#   https://dlocal.brunoelleon.com/admin/ab-test/stats (requiere Basic Auth)
UPSELL_AB_TEST_ENABLED=false
UPSELL_AMOUNT_VARIANT_B=147

# Dashboard de A/B test (Basic Auth). Si las dos variables NO están seteadas,
# el endpoint /admin/ab-test/stats devuelve 503 (acceso deshabilitado por seguridad).
# Para producción, usá un password fuerte (cualquier generador random sirve).
ADMIN_USERNAME=<<< usuario_para_ver_dashboard >>>
ADMIN_PASSWORD=<<< password_fuerte_para_ver_dashboard >>>

# Path donde se persisten los counters del A/B test. En Render, hay que montar
# un Disk en /data y dejar este path así para que sobreviva redeploys.
# Si corrés local, cambialo a algo tipo "./data/ab_test_stats.json".
AB_TEST_DATA_PATH=/data/ab_test_stats.json

# URLs a las que se redirige al cliente DESPUÉS de tocar el botón "Sí, sumar 3 meses"
# (endpoint /api/upsell/click/{payment_id}). Ambas opcionales:
# si no están seteadas, la API devuelve una página HTML simple.
# UPSELL_SUCCESS_URL=https://tu-dominio.com/upsell-confirmado
# UPSELL_ERROR_URL=https://tu-dominio.com/upsell-rechazado

# A dónde va el botón "No, gracias" en la página de oferta servida por la API
# (endpoint GET /upsell/{payment_id}). Si queda vacía, redirige al home.
UPSELL_DECLINE_URL=https://bruno.11demayo.com/graciasn


# ============================================================
# 7. META (FACEBOOK) PIXEL + CONVERSIONS API
# ============================================================
# Tracking de conversiones de Meta. El pixel_id se inyecta en el HTML para
# trackear del lado cliente; el access_token se usa server-side para mandar
# eventos via Conversions API (más confiable, no lo bloquean ad-blockers).
#
# IMPORTANTE: el access token es SECRETO. NUNCA commitearlo. Si se filtra,
# rotalo desde Meta Business Suite → Configuración del Pixel → Token de acceso.
META_PIXEL_ID=<<< TU_PIXEL_ID >>>
META_ACCESS_TOKEN=<<< TU_ACCESS_TOKEN_DE_CONVERSIONS_API >>>


# ============================================================
# 8. CONFIGURACIÓN GENERAL
# ============================================================
# production / development → afecta logs, reload, manejo de errores.
ENVIRONMENT=production

# Nivel de logs: DEBUG / INFO / WARNING / ERROR
# - INFO: recomendado en producción
# - DEBUG: solo si estás debuggeando un problema
LOG_LEVEL=INFO
